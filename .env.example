# ---------------------------------------------------------------------------
# Despeja environment variables  (copy to ".env.local" and fill in)
# ---------------------------------------------------------------------------
# The app runs fully WITHOUT a key. Adding one turns on the optional
# "Explain this simply" button, which rewrites a result in plain language,
# grounded ONLY in that program's verified facts + official source.
# The key stays on the server and is never sent to the browser.
# Get one at https://console.anthropic.com

ANTHROPIC_API_KEY=

# Confirm current model names: https://docs.claude.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
